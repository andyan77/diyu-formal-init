# Local PostgreSQL roles are intentionally separate. Do not put production credentials here.
DIYU_MIGRATOR_DATABASE_URL=postgresql://diyu_migrator@/diyu_m3?host=/absolute/path/to/var/postgres/socket&port=55432
DIYU_APP_DATABASE_URL=postgresql://diyu_app@/diyu_m3?host=/absolute/path/to/var/postgres/socket&port=55432
DIYU_SESSION_SECRET=replace-with-a-local-random-value
DIYU_DEMO_TENANT_ID=00000000-0000-0000-0000-000000000001
DIYU_DEMO_USER_ID=00000000-0000-0000-0000-000000000011
DIYU_DEMO_BRAND_ID=00000000-0000-0000-0000-000000000021
DIYU_DEMO_ACCOUNT_ID=00000000-0000-0000-0000-000000000031
# `stub` is the deterministic local test double. `deepseek` requires all three values below.
DIYU_GENERATOR_MODE=stub
DEEPSEEK_API_BASE_URL=https://provider-compatible-endpoint.example/v1
DEEPSEEK_API_KEY=never-commit-a-real-key
DEEPSEEK_MODEL=provider-verified-model-id
