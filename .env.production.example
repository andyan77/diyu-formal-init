# Copy to ECS /etc/diyu/app.env with mode 0600. Values below are placeholders only.
DIYU_RUNTIME_MODE=production
DIYU_APP_DATABASE_URL=postgresql://diyu_app:replace-with-app-password@127.0.0.1:5432/diyu_m5_4
DIYU_SESSION_SECRET=replace-with-a-random-server-secret
DIYU_GENERATOR_MODE=deepseek
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=copy-from-authorized-root-only-source
DEEPSEEK_MODEL=deepseek-v4-flash
DIYU_S3_ENDPOINT_URL=http://127.0.0.1:9000
DIYU_S3_BUCKET=diyu-m5-4-materials
DIYU_S3_ACCESS_KEY_ID=replace-with-dedicated-minio-access-key
DIYU_S3_SECRET_ACCESS_KEY=replace-with-dedicated-minio-secret
DIYU_S3_REGION=us-east-1
DIYU_LOGIN_RATE_LIMIT_PER_MINUTE=10
DIYU_MODEL_GLOBAL_CONCURRENCY=4
DIYU_MODEL_TENANT_CONCURRENCY=2
DIYU_MODEL_TENANT_RATE_PER_MINUTE=12
DIYU_MODEL_TIMEOUT_SECONDS=45
DIYU_MODEL_MAX_RETRIES=2
DIYU_PUBLIC_URL=https://diyuai.cc

# Keep separately in /etc/diyu/migrator.env; never expose it to the long-running app.
# DIYU_MIGRATOR_DATABASE_URL=postgresql://diyu_migrator:replace-with-migrator-password@127.0.0.1:5432/diyu_m5_4

# Keep separately in /etc/diyu/bootstrap.env for one-time initialization, then delete it.
# DIYU_BOOTSTRAP_OUTPUT_PATH=/run/diyu-ops/bootstrap-output
# DIYU_INITIAL_OPS_USERNAME=diyu-ops
# DIYU_INITIAL_OPS_PASSWORD=replace-with-random-password
# DIYU_INITIAL_DEMO_ADMIN_USERNAME=folding-admin
